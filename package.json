{
  "name": "sourdough-and-pizza-bakery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon backend/server.js",
    "start:backend": "node backend/server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:web": "wdio run ./wdio.web.conf.cjs",
    "test:mobile": "node ./scripts/run-mobile-tests.js",
    "test:qa": "npm run test:api ; npm run test:web",
    "appium": "appium",
    "test:api": "wdio run ./wdio.api.conf.cjs",
    "test:cucumber:web": "wdio run ./wdio.conf.js",
    "test:cucumber:mobile": "cross-env TEST_PLATFORM=mobile wdio run ./wdio.conf.js",
    "test:cucumber": "npm run test:cucumber:web",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "i18next": "^25.10.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/allure-reporter": "^9.26.1",
    "@wdio/appium-service": "^9.26.1",
    "@wdio/cli": "^9.26.1",
    "@wdio/cucumber-framework": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "allure-commandline": "^2.38.1",
    "appium": "^3.2.2",
    "appium-uiautomator2-driver": "^7.0.0",
    "chromedriver": "^146.0.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "webdriverio": "^9.26.1"
  }
}
